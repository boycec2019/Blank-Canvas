{
  "manifest_version": 3,
  "name": "Blank Canvas",
  "description": "Declutter Canvas with a configurable minimalist dashboard and built-in diagnostics.",
  "version": "0.1.0",
  "permissions": [
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "action": {
    "default_title": "Blank Canvas",
    "default_popup": "src/popup/popup.html"
  },
  "options_page": "src/options/options.html",
  "content_scripts": [
    {
      "matches": [
        "https://*/*",
        "http://*/*"
      ],
      "js": [
        "src/shared/core.js",
        "src/shared/defaults.js",
        "src/shared/ui.js",
        "src/shared/course-nav-utils.js",
        "src/shared/custom-assignments.js",
        "src/shared/custom-assignment-form.js",
        "src/shared/ignored-assignments.js",
        "src/content/bootstrap.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://*/*",
        "http://*/*"
      ],
      "js": [
        "src/shared/core.js",
        "src/shared/defaults.js",
        "src/shared/ui.js",
        "src/shared/course-nav-utils.js",
        "src/shared/debug.js",
        "src/shared/storage.js",
        "src/shared/custom-assignments.js",
        "src/shared/custom-assignment-form.js",
        "src/shared/ignored-assignments.js",
        "src/content/global-nav.js",
        "src/content/selectors.js",
        "src/content/dashboard-header.js",
        "src/content/assignment-utils.js",
        "src/content/assignment-course-resolver.js",
        "src/content/assignment-display.js",
        "src/content/assignment-row-model.js",
        "src/content/assignment-formatters.js",
        "src/content/assignment-dom.js",
        "src/content/assignment-api.js",
        "src/content/assignment-store-state.js",
        "src/content/assignment-refresh.js",
        "src/content/assignments.js",
        "src/content/rules.js",
        "src/content/course-nav.js",
        "src/content/feature-registry.js",
        "src/content/focused-pages.js",
        "src/content/ui-primitives.js",
        "src/content/diagnostics.js",
        "src/content/dashboard-widget-actions.js",
        "src/content/dashboard-row-renderer.js",
        "src/content/custom-assignment-schedule.js",
        "src/content/custom-assignment-modal-styles.js",
        "src/content/custom-assignment-modal.js",
        "src/content/dashboard-styles.js",
        "src/content/dashboard-view.js",
        "src/content/dashboard-layout.js",
        "src/content/dashboard.js",
        "src/content/feature-definitions.js",
        "src/content/theme-styles.js",
        "src/content/renderer.js",
        "src/content/main.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
